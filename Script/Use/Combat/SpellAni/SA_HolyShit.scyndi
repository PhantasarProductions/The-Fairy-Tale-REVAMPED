module 
	// SpellAni_Holy_Shit
	
	#use "Libs/SCI/Audio"
	#use "libs/SCI/Graphics"
	
	#use "Script/Use/Combat/SpellAni/SA_Shine"

	var koor
	var stront
	//var shine
	bool schijn = false
	var act
	
	locextern shine "Scyndi.Class.SA_Shine"
	
	int y
	readonly int midy
	readonly int midx
		
	Bool Ended

	Init
		koor = Audio.LoadNew("audio/spellani/choir.wav","Holy_Shit_Koor")
		stront = LoadNewImage("gfx/combat/spellani/poep.png","Holy_Shit_Shit")
		stront.HotCenter()
		midy = math.floor(Graphics.H/2)
		midx = math.floor(Graphics.W/2)
		//shine = NIL.Use("Script/Use/Specific/CombatModules/SpellAni/Shine")
	end
	
	void Start(_act)
		y = -1000
		koor.Play()		
		act=_act
	end
	
	bool Cycle()
		stront.Draw(midx,y)
		if y<midy
			y++
			return false
		elseif y==midy && (! schijn)
			shine.Start(act)			
			schijn=true
		end
		return shine.Cycle(act)
	end
	
	Void Draw()
		Ended = Cycle()
	End
	
	Void Update()
	End

//end
